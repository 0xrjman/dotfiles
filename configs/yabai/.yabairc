#!/usr/bin/env sh

# the scripting-addition must be loaded manually if
# you are running yabai on macOS Big Sur. Uncomment
# the following line to have the injection performed
# when the config is executed during startup.
#
# for this to work you must configure sudo such that
# it will be able to run the command without password
#
# see this wiki page for information:
#  - https://github.com/koekeishiya/yabai/wiki/Installing-yabai-(latest-release)
#
sudo yabai --load-sa
yabai -m signal --add event=dock_did_restart action="sudo yabai --load-sa"

# global settings
yabai -m config \
    mouse_follows_focus off \
    focus_follows_mouse off \
    window_origin_display default \
    window_placement second_child \
    window_topmost off \
    window_shadow on \
    window_opacity on \
    window_opacity_duration 0.0 \
    active_window_opacity 0.90 \
    normal_window_opacity 0.85 \
    insert_feedback_color 0xffd75f5f \
    split_ratio 0.50 \
    auto_balance off \
    mouse_modifier alt \
    mouse_action1 move \
    mouse_action2 resize \
    mouse_drop_action swap \
    layout bsp \
    top_padding 4 \
    bottom_padding 4 \
    left_padding 8 \
    right_padding 8 \
    window_gap 06
# status_bar                   off            \
# status_bar_text_font         "Helvetica Neue:Bold:12.0" \
# status_bar_icon_font         "FontAwesome 6:Regular:12.0" \
# status_bar_background_color  0xff202020                 \
# status_bar_foreground_color  0xffa8a8a8                 \
# status_bar_space_icon_strip  I II III IV V VI VII VIII IX X \
# status_bar_space_icon_strip  I II III IV V VI VII VIII IX X
# status_bar_power_icon_strip                                 \
# status_bar_space_icon                                      \
# status_bar_clock_icon                                      \

# ===== Spacebar ===============================
# SPACEBAR_HEIGHT=$(spacebar -m config height)
# yabai -m config external_bar all:0:$SPACEBAR_HEIGHT
yabai -m config external_bar all:35:0

# ===== Rules ==================================
# opacity=0.5
yabai -m rule --add app="^Monica$" manage=off
yabai -m rule --add app="^System Settings$" manage=off
yabai -m rule --add app="^OpenAI Translator$" manage=off
yabai -m rule --add app="^NetEaseMusic$" manage=off

# ===== App → Space auto-routing ======
# zen → space 2
yabai -m rule --add app="^zen$" space=2
# Zed: first window handled by signal below (space 5), subsequent→space 6
# (no static rule for zed, uses event signal instead)
# WPS / Notion / Obsidian → space 4
yabai -m rule --add app="^wpsoffice$" space=4
yabai -m rule --add app="^Notion$" space=4
yabai -m rule --add app="^Obsidian$" space=4
# WeChat / LX Music → space 3
yabai -m rule --add app="^WeChat$" space=3
yabai -m rule --add app="^lx-music-desktop$" space=3

# ===== Signal: Zed multi-window routing ======
# First Zed → space 5, second+ → space 6
yabai -m signal --add event=window_created action="$HOME/bin/route-zed-window.sh"

# ===== Signal: lx-music-desktop → space 3 ======
# Catches new window creation and existing windows when app comes to front
yabai -m signal --add event=window_created action="$HOME/bin/route-lxmusic-window.sh"
yabai -m signal --add event=application_front_switched action="$HOME/bin/route-lxmusic-window.sh"

# ===== manage=on rules (opacity=1.0 to avoid double-stacking) ======
# Clean up any stale runtime rules from prior sessions first
# (see pit #22: yabai -m rule --add at runtime persists in memory)
yabai -m rule --remove "^neovide$" 2>/dev/null
yabai -m rule --remove "^Alacritty$" 2>/dev/null
# Neovide: manage=on required for yabai toggle; auto-floated by toggle script
# opacity=1.0 so neovide_opacity controls transparency alone
yabai -m rule --add app="^neovide$" opacity=1.0
# Alacritty: manage=on required for yabai toggle; auto-floated by toggle script
# opacity=1.0 so alacritty.toml opacity controls transparency alone
yabai -m rule --add app="^Alacritty$" opacity=1.0

# Start JankyBorders (window borders via Quartz, not SA-dependent)
borders active_color=0xff775759 inactive_color=0xff555555 width=6.0 style=round &

yabai -m rule --apply

# ===== Auto-create spaces 1-7 =====
# Space 7 is used as stash space for toggle scripts (Alacritty/Neovide)
for idx in 1 2 3 4 5 6 7; do
    yabai -m query --space "$idx" >/dev/null 2>&1 || yabai -m space --create
done

# Delete extra spaces beyond 7
for idx in $(yabai -m query --spaces | jq -r '.[].index' | sort -nr); do
    [ "$idx" -gt 7 ] && yabai -m space --destroy "$idx"
done

echo "yabai configuration loaded.."
